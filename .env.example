# Supabase — get these from your Supabase project → Settings → API
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Admin URL slug — only you will know this path
# Your admin pages will live at /admin/YOUR_SLUG and /draft/YOUR_SLUG
# Make it something non-obvious (e.g., hff-draft-2026)
VITE_ADMIN_SLUG=your-secret-slug-here
